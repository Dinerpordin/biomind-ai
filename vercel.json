{
  "headers": [
    {
      "source": "/app/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/app/:path*",
      "destination": "/app/index.html"
    },
    {
      "source": "/",
      "destination": "/explore.html"
    }
  ]
}
